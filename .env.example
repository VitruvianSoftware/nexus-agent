# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Comma-separated list of allowed Telegram user IDs
# Find your ID by messaging @userinfobot on Telegram
ALLOWED_USER_IDS=

# Working directory for Gemini CLI (where it will read/write files)
GEMINI_WORKING_DIR=/Users/james/.gemini/antigravity/playground/azure-parsec

# Max execution time per prompt in milliseconds (default: 5 minutes)
GEMINI_TIMEOUT_MS=300000

# Gemini CLI approval mode: default, auto_edit, yolo
GEMINI_APPROVAL_MODE=yolo

# Gemini CLI model (optional, leave blank for default)
GEMINI_MODEL=

# Enable thinking mode for deep reasoning (uses gemini-2.5-flash, longer timeout)
# Set to "true" to enable, anything else to disable
GEMINI_THINKING=false
